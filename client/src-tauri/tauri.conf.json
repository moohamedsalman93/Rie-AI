{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Rie-AI",
    "version": "0.1.0",
    "identifier": "com.ai.rie-ai",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:14200",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Rie-AI",
                "width": 360,
                "height": 520,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "shadow": false,
                "skipTaskbar": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [],
        "externalBin": [
            "bin/rie-backend"
        ]
    },
    "plugins": {
       
    }
}